# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here-minimum-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Base de données ───────────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=siguvh_db
DB_USER=siguvh_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@siguvh.edu
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=SIGUVH <noreply@siguvh.edu>

# ── Stockage fichiers ─────────────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=siguvh-media
AWS_S3_REGION_NAME=us-east-1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Frontend (liens de vérification dans les PDF générés) ────────────────────
FRONTEND_URL=https://yourdomain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=8
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── SMS Gateway (optionnel) ───────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=+1234567890

# ── Sentry (monitoring) ───────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Assistant IA — Claude / Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
